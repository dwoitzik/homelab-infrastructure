kind: ConfigMap
metadata:
  annotations:
    argocd.argoproj.io/tracking-id: authelia:/ConfigMap:apps/authelia-config
    kubectl.kubernetes.io/last-applied-configuration: |
      {"apiVersion":"v1","data":{"configuration.yml":"server:\n  address: 'tcp://0.0.0.0:9091/'\nlog:\n  level: 'debug'\n\nidentity_validation:\n  reset_password:\n    jwt_secret: '/config/secrets/jwt-secret'\n\ndefault_redirection_url: 'https://auth.woitzik.dev'\n\nauthentication_backend:\n  file:\n    path: '/config/users/users_database.yml'\n\nsession:\n  name: 'authelia_session'\n  domain: 'woitzik.dev'\n  secret: '/config/secrets/session-secret'\n  same_site: 'lax'\n  expiration: '1h'\n  inactivity: '5m'\n  remember_me: '1M'\n  redis:\n    host: 'redis-authelia.database.svc.cluster.local'\n    port: 6379\n    database_index: 0\n\nstorage:\n  encryption_key: '/config/secrets/storage-key'\n  postgres:\n    address: 'tcp://postgres-authelia.database.svc.cluster.local:5432'\n    database: 'authelia'\n    username: 'authelia'\n\nnotifier:\n  filesystem:\n    filename: '/tmp/notification.txt'\n\naccess_control:\n  default_policy: 'one_factor'\n  rules:\n    - domain: 'pve.woitzik.dev'\n      policy: 'two_factor'\n      subject:\n        - 'group:admins'\n    - domain: '*.woitzik.dev'\n      policy: 'two_factor'\n    - domain: 'auth.woitzik.dev'\n      policy: 'bypass'\n\nidentity_providers:\n  oidc:\n    hmac_secret: \"dubist1plebyakalb\"\n    issuer_private_key: |\n      -----BEGIN PRIVATE KEY-----\n      MIIJQwIBADANBgkqhkiG9w0BAQEFAASCCS0wggkpAgEAAoICAQDSbHd2BIra2jgE\n      9IvQzQALEEsVUdNkilmziwL0BQ/SUUhtQvq20be3ZZ9JyFlzsAR7mfHtCfzNfd9g\n      gsILGinDt9c71LHHS/xSw7V0l6JdR+8ye4/gK3bjLGjI28hR9YqmtduAs0q3ITXW\n      cjQfIUnZOyIgwIeUYHGV7/SUDarTZowwdIbSr9+N0y5aFWKD3ihT00PWyv8Kunuh\n      xSsswKVMr9QrUqwhaJrW+ynVflCKNQlrvbFluHfx0lE9lBYdxMXjgKC4bRWX/RII\n      vrTMyHKCPwg2SJXDnRrW9EmEq5R1XY0MZTySaDA/wVXK3Y05J/Il01sn+MgLJyg2\n      URA9ZUMjFUfmisYlRTGL16B9TqUS8/fszQzb9RT6Q8yv8GxvW11TpIqX3zWiwAhT\n      lWOKYenyd7tQo7J2dHZ94v18ldok7u+Y0ATvcIUgMIL08SG5ae2/50nixMnOOY7l\n      bPCA5K2gpxCwjHGSVrfBTSyEAo68yGV+MLJUIq6efn2RbUsxCNoF0e50FM1UwdiW\n      QHchx1ijs0xprv5nGOqrCEY1b