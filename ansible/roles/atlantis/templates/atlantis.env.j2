# Atlantis server
ATLANTIS_ATLANTIS_URL=https://{{ atlantis_hostname }}
ATLANTIS_PORT=4141
ATLANTIS_REPO_ALLOWLIST=github.com/{{ atlantis_gh_user }}/{{ atlantis_gh_repo }}

# GitHub integration
ATLANTIS_GH_USER={{ atlantis_gh_user }}
ATLANTIS_GH_TOKEN={{ atlantis_gh_token }}
ATLANTIS_GH_WEBHOOK_SECRET={{ atlantis_gh_webhook_secret }}

# Terraform variables
TF_VAR_mikrotik_url={{ atlantis_tf_mikrotik_url }}
TF_VAR_mikrotik_user={{ atlantis_tf_mikrotik_user }}
TF_VAR_mikrotik_password={{ atlantis_tf_mikrotik_password }}
TF_VAR_mikrotik_insecure=true

# Minio backend
AWS_ACCESS_KEY_ID={{ minio_root_user }}
AWS_SECRET_ACCESS_KEY={{ minio_root_password }}
