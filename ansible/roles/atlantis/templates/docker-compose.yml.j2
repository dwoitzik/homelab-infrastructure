services:
  atlantis:
    image: ghcr.io/runatlantis/atlantis:{{ atlantis_version }}
    container_name: atlantis
    restart: unless-stopped
    env_file: .env
    ports:
      - "{{ atlantis_port }}:4141"
    volumes:
      - ./data:/home/atlantis
      - ./repos.yaml:/etc/atlantis/repos.yaml:ro
    command:
      - server
      - --repo-config=/etc/atlantis/repos.yaml
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:4141/healthz"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 10s

networks:
  default:
    name: atlantis
