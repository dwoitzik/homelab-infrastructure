global
    log /dev/log local0
    log /dev/log local1 notice
    chroot /var/lib/haproxy
    stats socket /run/haproxy/admin.sock mode 660 level admin expose-fd listeners
    stats timeout 30s
    user haproxy
    group haproxy
    daemon

defaults
    log     global
    mode    tcp
    option  tcplog
    timeout connect 5s
    timeout client  50s
    timeout server  50s

# High Availability Frontend (VIP: 10.0.20.5)
frontend k3s_gateway
    bind 10.0.20.5:80
    bind 10.0.20.5:443
    default_backend k3s_traefik

# Backend pointing to K3s Traefik
backend k3s_traefik
    mode tcp
    balance roundrobin
    # Leitet Traffic an den Original-Port weiter, checkt aber via Port 80
    server k3s_node_01 10.0.20.200 check port 80
