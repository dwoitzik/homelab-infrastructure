server:
    interface: 0.0.0.0
    port: 53
    do-ip4: yes
    do-udp: yes
    do-tcp: yes

    access-control: 127.0.0.0/8 allow
    access-control: 10.0.0.0/8 allow
    access-control: 172.16.0.0/12 allow
    access-control: 192.168.0.0/16 allow

    hide-identity: yes
    hide-version: yes
    prefetch: yes
    prefetch-key: yes
    serve-expired: yes
    serve-expired-ttl: 0
    cache-min-ttl: 0
    msg-cache-size: 64m
    rrset-cache-size: 128m

    do-daemonize: no
    username: "unbound"
    chroot: ""

    so-rcvbuf: 0
    so-sndbuf: 0
