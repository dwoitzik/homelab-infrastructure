global:
  resolve_timeout: 5m

route:
  group_by: ['alertname', 'instance']
  group_wait: 30s
  group_interval: 5m
  repeat_interval: 4h
  receiver: 'default'

receivers:
  - name: 'default'
{% if alertmanager_gotify_url is defined %}
    webhook_configs:
      - url: '{{ alertmanager_gotify_url }}/message?token={{ alertmanager_gotify_token }}'
        send_resolved: true
{% else %}
    # No notification provider configured.
{% endif %}

inhibit_rules:
  - source_match:
      severity: 'critical'
    target_match:
      severity: 'warning'
    equal: ['alertname', 'instance']
